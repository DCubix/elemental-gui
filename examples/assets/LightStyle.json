{
    "$variables": {
        "primary": "#FF2563EB",
        "primaryHover": "#FF3B82F6",
        "primaryClick": "#FF1D4ED8",
        "secondary": "#FFD1D5DB",
        "secondaryHover": "#FF9CA3AF",
        "secondaryClick": "#FFF3F4F6",
        "accent": "#FF4F46E5",
        "accentHover": "#FF6366F1",
        "accentClick": "#FF4338CA",
        "textPrimary": "#FF000000",
        "textSecondary": "#FF4B5563",
        "textAccent": "#FFFFFFFF",
        "textDisabled": "#FF9CA3AF",
        "backgroundDark": "#FFF9FAFB",
        "borderDark": "#FFE5E7EB",
        "panelBackground": "#FFFFFFFF",
        "textPrimaryBright": "#FFCCCCCC",
        "thumbNormalBorder": "#FFD1D5DB",
        "thumbHoverBorder": "#FF9CA3AF",
        "thumbClickBorder": "#FF4B5563",
        "thumbHoverBackground": "#FFE5E7EB",
        "thumbClickBackground": "#FFD1D5DB",
        "focusBlue": "#FF3B82F6",
        "selectionBlue": "#FF2563EB",
        "switchOffBorder": "#FFD1D5DB",
        "switchOffBackground": "#FFE5E7EB",
        "switchOnBackground": "#FF2563EB",
        "switchThumbBackground": "#FFFFFFFF",
        "switchThumbHoverBorder": "#FF9CA3AF",
        "switchThumbHoverBackground": "#FFF3F4F6",
        "switchThumbClickBackground": "#FFF9FAFB",
        "switchThumbOnBorder": "#FF1D4ED8",
        "switchThumbOnBackground": "#FFFFFFFF",
        "switchThumbOnHoverBorder": "#FF1D4ED8",
        "switchThumbOnHoverBackground": "#FFF3F4F6",
        "switchThumbOnClickBackground": "#FFF9FAFB",
        "checkboxHoverBorder": "#FF3B82F6",
        "hoverBackground": "#FFF3F4F6",
        "clickBackground": "#FFE5E7EB",
        "white": "#FFFFFFFF",
        "menuItemClick": "#FFE5E7EB",
        "spinnerButtonHover": "#FFF3F4F6",
        "spinnerButtonClick": "#FFE5E7EB",
        "primaryDarkTransparent": "#002563EB"
    },
    "Window": {
        "background": {
            "color": "$secondaryClick"
        }
    },
    "DefaultText": {
        "font": "Sans",
        "fontSize": 16.0,
        "fontSlant": "normal",
        "fontWeight": "normal",
        "color": "$textPrimary"
    },
    "DefaultTextBig": {
        "font": "Sans",
        "fontSize": 26.0,
        "fontSlant": "normal",
        "fontWeight": "bold"
    },
    "Default": {
        "background": {
            "color": "$secondaryClick"
        }
    },
    "Panel": {
        "elevation": 4.0,
        "border": {
            "radius": 4.0,
            "color": "$borderDark",
            "width": 1.0
        },
        "background": {
            "color": "$panelBackground"
        }
    },
    "Button": {
        "padding": {
            "horizontal": 20.0,
            "vertical": 10.0
        },
        "normal": {
            "elevation": 4.0,
            "border": {
                "radius": 4.0,
                "color": "$primary",
                "width": 1.0
            },
            "background": {
                "color": "$primary"
            },
            "text": {
                "color": "$textAccent"
            }
        },
        "hover": {
            "elevation": 4.0,
            "border": {
                "radius": 4.0,
                "color": "$primaryHover",
                "width": 1.0
            },
            "background": {
                "color": "$primaryHover"
            },
            "text": {
                "color": "$textAccent"
            }
        },
        "click": {
            "elevation": 4.0,
            "border": {
                "radius": 4.0,
                "color": "$primaryClick",
                "width": 1.0
            },
            "background": {
                "color": "$primaryClick"
            },
            "text": {
                "color": "$textAccent"
            }
        }
    },
    "Scrollbar": {
        "track": {
            "border": {
                "radius": 4.0,
                "color": "$borderDark",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "thumb": {
            "normal": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbNormalBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$secondary"
                }
            },
            "hover": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbHoverBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$thumbHoverBackground"
                }
            },
            "click": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbClickBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$thumbClickBackground"
                }
            }
        }
    },
    "Slider": {
        "track": {
            "border": {
                "radius": 4.0,
                "color": "$borderDark",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "thumb": {
            "normal": {
                "elevation": 2.0,
                "border": {
                    "radius": 999.0,
                    "color": "$primary",
                    "width": 1.0
                },
                "background": {
                    "color": "$primary"
                }
            },
            "hover": {
                "elevation": 2.0,
                "border": {
                    "radius": 999.0,
                    "color": "$primaryHover",
                    "width": 1.0
                },
                "background": {
                    "color": "$primaryHover"
                }
            },
            "click": {
                "elevation": 2.0,
                "border": {
                    "radius": 999.0,
                    "color": "$primaryClick",
                    "width": 1.0
                },
                "background": {
                    "color": "$primaryClick"
                }
            }
        }
    },
    "Edit": {
        "padding": {
            "horizontal": 8.0,
            "vertical": 4.0
        },
        "normal": {
            "border": {
                "radius": 4.0,
                "color": "$secondary",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "hover": {
            "border": {
                "radius": 4.0,
                "color": "$secondaryHover",
                "width": 1.0
            },
            "background": {
                "color": "$secondaryClick"
            }
        },
        "focused": {
            "border": {
                "radius": 4.0,
                "color": "$focusBlue",
                "width": 2.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        }
    },
    "Selection": {
        "background": {
            "color": "$selectionBlue"
        }
    },
    "Switch": {
        "track": {
            "off": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchOffBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchOffBackground"
                }
            },
            "on": {
                "border": {
                    "radius": 999.0,
                    "color": "$accentClick",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchOnBackground"
                }
            }
        },
        "thumb": {
            "normal": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbHoverBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbBackground"
                }
            },
            "hover": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbHoverBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbHoverBackground"
                }
            },
            "click": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbClickBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbClickBackground"
                }
            },
            "normalOn": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbOnBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbOnBackground"
                }
            },
            "hoverOn": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbOnHoverBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbOnHoverBackground"
                }
            },
            "clickOn": {
                "border": {
                    "radius": 999.0,
                    "color": "$accentClick",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbOnClickBackground"
                }
            }
        }
    },
    "CheckBox": {
        "size": 20.0,
        "normal": {
            "border": {
                "radius": 4.0,
                "color": "$switchOffBorder",
                "width": 1.0
            },
            "background": {
                "color": "$switchOffBackground"
            }
        },
        "hover": {
            "border": {
                "radius": 4.0,
                "color": "$checkboxHoverBorder",
                "width": 1.0
            },
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 4.0,
                "color": "$primaryClick",
                "width": 1.0
            },
            "background": {
                "color": "$clickBackground"
            }
        },
        "checked": {
            "border": {
                "radius": 4.0,
                "color": "$accent",
                "width": 1.0
            },
            "background": {
                "color": "$accent"
            }
        },
        "checkedHover": {
            "border": {
                "radius": 4.0,
                "color": "$accentHover",
                "width": 1.0
            },
            "background": {
                "color": "$accentHover"
            }
        },
        "checkmark": {
            "stroke": {
                "color": "$white",
                "width": 2.0
            },
            "lineCap": "round",
            "lineJoin": "round",
            "svg": "M20 6 9 17l-5-5"
        }
    },
    "RadioButton": {
        "size": 20.0,
        "normal": {
            "border": {
                "radius": 999.0,
                "color": "$switchOffBorder",
                "width": 1.0
            },
            "background": {
                "color": "$switchOffBackground"
            }
        },
        "hover": {
            "border": {
                "radius": 999.0,
                "color": "$checkboxHoverBorder",
                "width": 1.0
            },
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 999.0,
                "color": "$primaryClick",
                "width": 1.0
            },
            "background": {
                "color": "$clickBackground"
            }
        },
        "selected": {
            "border": {
                "radius": 999.0,
                "color": "$accent",
                "width": 1.0
            },
            "background": {
                "color": "$accent"
            }
        },
        "selectedHover": {
            "border": {
                "radius": 999.0,
                "color": "$accentHover",
                "width": 1.0
            },
            "background": {
                "color": "$accentHover"
            }
        },
        "dot": {
            "border": {
                "radius": 999.0,
                "color": "$white",
                "width": 0.0
            },
            "background": {
                "color": "$white"
            }
        }
    },
    "Menu": {
        "elevation": 8.0,
        "padding": {
            "horizontal": 0.0,
            "vertical": 8.0
        },
        "border": {
            "radius": 4.0,
            "color": "$secondary",
            "width": 1.0
        },
        "background": {
            "color": "$panelBackground"
        }
    },
    "MenuItem": {
        "padding": {
            "horizontal": 14.0,
            "vertical": 8.0
        },
        "normal": {
            "background": {
                "color": "#00000000"
            }
        },
        "hover": {
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "background": {
                "color": "$menuItemClick"
            }
        },
        "arrow": {
            "stroke": {
                "color": "$textSecondary",
                "width": 2.0
            },
            "lineCap": "round",
            "lineJoin": "round",
            "svg": "m9 18 6-6-6-6"
        }
    },
    "MenuSeparator": {
        "color": "$secondary",
        "margin": {
            "horizontal": 12.0,
            "vertical": 6.0
        }
    },
    "List": {
        "padding": 8.0,
        "border": {
            "radius": 4.0,
            "color": "$secondary",
            "width": 1.0
        },
        "background": {
            "color": "$backgroundDark"
        },
        "item": {
            "height": 22.0,
            "padding": {
                "vertical": 8.0,
                "horizontal": 12.0
            }
        },
        "itemSelected": {
            "border": {
                "radius": 4.0,
                "color": "$white",
                "width": 0.0
            },
            "background": {
                "color": "$selectionBlue"
            },
            "text": {
                "color": "$white",
                "fontWeight": "bold"
            }
        }
    },
    "ToolButton": {
        "padding": {
            "horizontal": 8.0,
            "vertical": 8.0
        },
        "hover": {
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 4.0,
                "color": "$primaryClick",
                "width": 1.0
            },
            "background": {
                "color": "$clickBackground"
            }
        }
    },
    "ProgressBar": {
        "track": {
            "border": {
                "radius": 4.0,
                "color": "$borderDark",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "progress": {
            "border": {
                "radius": 4.0,
                "color": "$primary",
                "width": 1.0
            },
            "background": {
                "color": "$primary"
            }
        },
        "indeterminate": {
            "background": {
                "linearGradient": {
                    "start": [
                        0.0,
                        0.0
                    ],
                    "end": [
                        1.0,
                        0.0
                    ],
                    "stops": [
                        0.0,
                        0.5,
                        1.0
                    ],
                    "colors": [
                        "$primaryDarkTransparent",
                        "$primary",
                        "$primaryDarkTransparent"
                    ]
                }
            }
        }
    },
    "Spinner": {
        "normal": {
            "border": {
                "radius": 4.0,
                "color": "$secondary",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "button": {
            "hover": {
                "border": {
                    "radius": 0.0,
                    "color": "$primaryHover",
                    "width": 0.0
                },
                "background": {
                    "color": "$spinnerButtonHover"
                }
            },
            "click": {
                "border": {
                    "radius": 0.0,
                    "color": "$primaryClick",
                    "width": 0.0
                },
                "background": {
                    "color": "$spinnerButtonClick"
                }
            }
        }
    }
}