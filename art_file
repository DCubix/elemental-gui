struct Color {
    float r, g, b, a;
};

struct Size {
    s32 w, h;
};

struct Point {
    s32 x, y;
};

struct Layer<auto N> {
    u32 id;
    Color data[N];
};

struct Art {
    Size imageSize;
    
    u32 paletteSize;
    Color palette[paletteSize];
    
    u32 globalId;
    float zoom;
    Point viewPosition;
    Color editorColors[2];
    
    u32 layerCount;
    u32 layerOrders[layerCount];
    
    Layer<imageSize.w * imageSize.h> layers[layerCount];
};

Art art @ 0x00;