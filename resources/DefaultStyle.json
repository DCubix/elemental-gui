{
    "$variables": {
        "primary": "#FF3859A6",
        "primaryHover": "#FF4D73CC",
        "primaryClick": "#FF2E4780",
        "secondary": "#FF383838",
        "secondaryHover": "#FF555555",
        "secondaryClick": "#FF1A1A1A",
        "accent": "#FF3D6BC7",
        "accentHover": "#FF5280E0",
        "accentClick": "#FF3866B8",
        "textPrimary": "#FFE0E0E0",
        "textSecondary": "#FFB8B8B8",
        "textDisabled": "#FF7A7A7A",
        "backgroundDark": "#FF141414",
        "borderDark": "#FF333333",
        "panelBackground": "#FF212121",
        "textPrimaryBright": "#FFEBEBEB",
        "primaryDark": "#FF294580",
        "primaryHoverDark": "#FF3359A3",
        "primaryClickDark": "#FF1A2E61",
        "thumbNormalBorder": "#FF474747",
        "thumbHoverBorder": "#FF616161",
        "thumbClickBorder": "#FF525252",
        "thumbHoverBackground": "#FF4D4D4D",
        "thumbClickBackground": "#FF2E2E2E",
        "focusBlue": "#FF2666D9",
        "selectionBlue": "#732666D9",
        "switchOffBorder": "#FF404045",
        "switchOffBackground": "#FF1F1F1F",
        "switchOnBackground": "#FF24478A",
        "switchThumbBackground": "#FF85858A",
        "switchThumbHoverBorder": "#FF7A7A80",
        "switchThumbHoverBackground": "#FF9E9EA3",
        "switchThumbClickBackground": "#FF6B6B70",
        "switchThumbOnBorder": "#FF4D80D9",
        "switchThumbOnBackground": "#FFA6BDE6",
        "switchThumbOnHoverBorder": "#FF6194EB",
        "switchThumbOnHoverBackground": "#FFB8CCF0",
        "switchThumbOnClickBackground": "#FF859ED6",
        "checkboxHoverBorder": "#FF4D73C7",
        "hoverBackground": "#FF24242B",
        "clickBackground": "#FF121217",
        "accentDark": "#FF2E5299",
        "accentHoverDark": "#FF3861B3",
        "white": "#FFFFFFFF",
        "menuItemClick": "#FF26478C",
        "spinnerButtonHover": "#FF2A2A40",
        "spinnerButtonClick": "#FF1A1A28",
        "primaryDarkTransparent": "#00294580"
    },
    "Window": {
        "background": {
            "color": "$secondaryClick"
        }
    },
    "DefaultText": {
        "font": "Sans",
        "fontSize": 16.0,
        "fontSlant": "normal",
        "fontWeight": "normal",
        "color": "$textPrimary"
    },
    "DefaultTextBig": {
        "font": "Sans",
        "fontSize": 26.0,
        "fontSlant": "normal",
        "fontWeight": "bold",
        "color": "$textPrimaryBright"
    },
    "Default": {
        "background": {
            "color": "$secondaryClick"
        }
    },
    "Panel": {
        "elevation": 4.0,
        "border": {
            "radius": 8.0,
            "color": "$borderDark",
            "width": 1.0
        },
        "background": {
            "color": "$panelBackground"
        }
    },
    "Button": {
        "padding": {
            "horizontal": 20.0,
            "vertical": 10.0
        },
        "normal": {
            "elevation": 4.0,
            "border": {
                "radius": 8.0,
                "color": "$primary",
                "width": 1.0
            },
            "background": {
                "color": "$primaryDark"
            }
        },
        "hover": {
            "elevation": 4.0,
            "border": {
                "radius": 8.0,
                "color": "$primaryHover",
                "width": 1.0
            },
            "background": {
                "color": "$primaryHoverDark"
            }
        },
        "click": {
            "elevation": 4.0,
            "border": {
                "radius": 8.0,
                "color": "$primaryClick",
                "width": 1.0
            },
            "background": {
                "color": "$primaryClickDark"
            }
        }
    },
    "Scrollbar": {
        "track": {
            "border": {
                "radius": 999.0,
                "color": "$borderDark",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "thumb": {
            "normal": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbNormalBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$secondary"
                }
            },
            "hover": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbHoverBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$thumbHoverBackground"
                }
            },
            "click": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbClickBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$thumbClickBackground"
                }
            }
        }
    },
    "Slider": {
        "track": {
            "border": {
                "radius": 6.0,
                "color": "$borderDark",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "thumb": {
            "normal": {
                "elevation": 2.0,
                "border": {
                    "radius": 999.0,
                    "color": "$primary",
                    "width": 1.0
                },
                "background": {
                    "color": "$primaryDark"
                }
            },
            "hover": {
                "elevation": 2.0,
                "border": {
                    "radius": 999.0,
                    "color": "$primaryHover",
                    "width": 1.0
                },
                "background": {
                    "color": "$primaryHoverDark"
                }
            },
            "click": {
                "elevation": 2.0,
                "border": {
                    "radius": 999.0,
                    "color": "$primaryClick",
                    "width": 1.0
                },
                "background": {
                    "color": "$primaryClickDark"
                }
            }
        }
    },
    "Edit": {
        "padding": {
            "horizontal": 8.0,
            "vertical": 4.0
        },
        "normal": {
            "border": {
                "radius": 8.0,
                "color": "$secondary",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "hover": {
            "border": {
                "radius": 8.0,
                "color": "$secondaryHover",
                "width": 1.0
            },
            "background": {
                "color": "$secondaryClick"
            }
        },
        "focused": {
            "border": {
                "radius": 8.0,
                "color": "$focusBlue",
                "width": 2.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        }
    },
    "Selection": {
        "background": {
            "color": "$selectionBlue"
        }
    },
    "Switch": {
        "track": {
            "off": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchOffBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchOffBackground"
                }
            },
            "on": {
                "border": {
                    "radius": 999.0,
                    "color": "$accentClick",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchOnBackground"
                }
            }
        },
        "thumb": {
            "normal": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbHoverBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbBackground"
                }
            },
            "hover": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbHoverBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbHoverBackground"
                }
            },
            "click": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbClickBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbClickBackground"
                }
            },
            "normalOn": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbOnBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbOnBackground"
                }
            },
            "hoverOn": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbOnHoverBorder",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbOnHoverBackground"
                }
            },
            "clickOn": {
                "border": {
                    "radius": 999.0,
                    "color": "$accentClick",
                    "width": 1.0
                },
                "background": {
                    "color": "$switchThumbOnClickBackground"
                }
            }
        }
    },
    "CheckBox": {
        "size": 20.0,
        "normal": {
            "border": {
                "radius": 6.0,
                "color": "$switchOffBorder",
                "width": 1.0
            },
            "background": {
                "color": "$switchOffBackground"
            }
        },
        "hover": {
            "border": {
                "radius": 6.0,
                "color": "$checkboxHoverBorder",
                "width": 1.0
            },
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 6.0,
                "color": "$primaryClick",
                "width": 1.0
            },
            "background": {
                "color": "$clickBackground"
            }
        },
        "checked": {
            "border": {
                "radius": 6.0,
                "color": "$accent",
                "width": 1.0
            },
            "background": {
                "color": "$accentDark"
            }
        },
        "checkedHover": {
            "border": {
                "radius": 6.0,
                "color": "$accentHover",
                "width": 1.0
            },
            "background": {
                "color": "$accentHoverDark"
            }
        },
        "checkmark": {
            "stroke": {
                "color": "$white",
                "width": 2.0
            },
            "lineCap": "round",
            "lineJoin": "round",
            "svg": "M20 6 9 17l-5-5"
        }
    },
    "RadioButton": {
        "size": 20.0,
        "normal": {
            "border": {
                "radius": 999.0,
                "color": "$switchOffBorder",
                "width": 1.0
            },
            "background": {
                "color": "$switchOffBackground"
            }
        },
        "hover": {
            "border": {
                "radius": 999.0,
                "color": "$checkboxHoverBorder",
                "width": 1.0
            },
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 999.0,
                "color": "$primaryClick",
                "width": 1.0
            },
            "background": {
                "color": "$clickBackground"
            }
        },
        "selected": {
            "border": {
                "radius": 999.0,
                "color": "$accent",
                "width": 1.0
            },
            "background": {
                "color": "$accentDark"
            }
        },
        "selectedHover": {
            "border": {
                "radius": 999.0,
                "color": "$accentHover",
                "width": 1.0
            },
            "background": {
                "color": "$accentHoverDark"
            }
        },
        "dot": {
            "border": {
                "radius": 999.0,
                "color": "$white",
                "width": 0.0
            },
            "background": {
                "color": "$white"
            }
        }
    },
    "Menu": {
        "elevation": 8.0,
        "padding": {
            "horizontal": 0.0,
            "vertical": 8.0
        },
        "border": {
            "radius": 10.0,
            "color": "$secondary",
            "width": 1.0
        },
        "background": {
            "color": "$hoverBackground"
        }
    },
    "MenuItem": {
        "padding": {
            "horizontal": 14.0,
            "vertical": 8.0
        },
        "normal": {
            "background": {
                "color": "#00000000"
            }
        },
        "hover": {
            "background": {
                "color": "$primaryHoverDark"
            }
        },
        "click": {
            "background": {
                "color": "$menuItemClick"
            }
        },
        "arrow": {
            "stroke": {
                "color": "$white",
                "width": 2.0
            },
            "lineCap": "round",
            "lineJoin": "round",
            "svg": "m9 18 6-6-6-6"
        }
    },
    "MenuSeparator": {
        "color": "$secondary",
        "margin": {
            "horizontal": 12.0,
            "vertical": 6.0
        }
    },
    "List": {
        "padding": 8.0,
        "border": {
            "radius": 8.0,
            "color": "$secondary",
            "width": 1.0
        },
        "background": {
            "color": "$backgroundDark"
        },
        "item": {
            "height": 22.0,
            "padding": {
                "vertical": 8.0,
                "horizontal": 12.0
            }
        },
        "itemSelected": {
            "border": {
                "radius": 6.0,
                "color": "$white",
                "width": 0.0
            },
            "background": {
                "color": "$selectionBlue"
            },
            "text": {
                "color": "$white",
                "fontWeight": "bold"
            }
        }
    },
    "ToolButton": {
        "padding": {
            "horizontal": 8.0,
            "vertical": 8.0
        },
        "hover": {
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 6.0,
                "color": "$primaryClick",
                "width": 1.0
            },
            "background": {
                "color": "$clickBackground"
            }
        }
    },
    "ProgressBar": {
        "track": {
            "border": {
                "radius": 6.0,
                "color": "$borderDark",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "progress": {
            "border": {
                "radius": 6.0,
                "color": "$primary",
                "width": 1.0
            },
            "background": {
                "color": "$primaryDark"
            }
        },
        "indeterminate": {
            "background": {
                "linearGradient": {
                    "start": [
                        0.0,
                        0.0
                    ],
                    "end": [
                        1.0,
                        0.0
                    ],
                    "stops": [
                        0.0,
                        0.5,
                        1.0
                    ],
                    "colors": [
                        "$primaryDarkTransparent",
                        "$primary",
                        "$primaryDarkTransparent"
                    ]
                }
            }
        }
    },
    "Spinner": {
        "normal": {
            "border": {
                "radius": 6.0,
                "color": "$secondary",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "button": {
            "hover": {
                "border": {
                    "radius": 0.0,
                    "color": "$primaryHover",
                    "width": 0.0
                },
                "background": {
                    "color": "$spinnerButtonHover"
                }
            },
            "click": {
                "border": {
                    "radius": 0.0,
                    "color": "$primaryClick",
                    "width": 0.0
                },
                "background": {
                    "color": "$spinnerButtonClick"
                }
            }
        }
    }
}