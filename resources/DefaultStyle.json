{
    "$variables": {
        "primary": "#FFFAFAFA",
        "primaryHover": "#FFF4F4F5",
        "primaryClick": "#FFE4E4E7",
        "secondary": "#FF27272A",
        "secondaryHover": "#FF3F3F46",
        "secondaryClick": "#FF09090B",
        "accent": "#FFFAFAFA",
        "accentHover": "#FFF4F4F5",
        "accentClick": "#FF3F3F46",
        "textPrimary": "#FFFAFAFA",
        "textSecondary": "#FFA1A1AA",
        "textDisabled": "#FF71717A",
        "backgroundDark": "#FF09090B",
        "backgroundLight": "#FFFCFCFC",
        "borderDark": "#FF27272A",
        "panelBackground": "#FF18181B",
        "textPrimaryBright": "#FFFAFAFA",
        "primaryDark": "#FF27272A",
        "primaryHoverDark": "#FF3F3F46",
        "primaryClickDark": "#FF18181B",
        "onPrimary": "#FF09090B",
        "thumbNormalBorder": "#FF3F3F46",
        "thumbHoverBorder": "#FF52525B",
        "thumbClickBorder": "#FF71717A",
        "thumbHoverBackground": "#FF3F3F46",
        "thumbClickBackground": "#FF52525B",
        "focusBlue": "#FFFAFAFA",
        "selectionBlue": "#FF3F3F46",
        "switchOffBorder": "#FF3F3F46",
        "switchOffBackground": "#FF27272A",
        "switchOnBackground": "#FFFAFAFA",
        "switchThumbBackground": "#FFA1A1AA",
        "switchThumbHoverBorder": "#FF71717A",
        "switchThumbHoverBackground": "#FFD4D4D8",
        "switchThumbClickBackground": "#FFA1A1AA",
        "switchThumbOnBorder": "#FFFAFAFA",
        "switchThumbOnBackground": "#FF09090B",
        "switchThumbOnHoverBorder": "#FFF4F4F5",
        "switchThumbOnHoverBackground": "#FF18181B",
        "switchThumbOnClickBackground": "#FF27272A",
        "checkboxHoverBorder": "#FFA1A1AA",
        "hoverBackground": "#FF27272A",
        "clickBackground": "#FF18181B",
        "accentDark": "#FFFAFAFA",
        "accentHoverDark": "#FFF4F4F5",
        "white": "#FFFFFFFF",
        "menuItemClick": "#FF3F3F46",
        "spinnerButtonHover": "#FF27272A",
        "spinnerButtonClick": "#FF18181B",
        "primaryDarkTransparent": "#00FAFAFA"
    },
    "Window": {
        "background": {
            "color": "$panelBackground"
        }
    },
    "DefaultText": {
        "font": "Sans",
        "fontSize": 16.0,
        "fontSlant": "normal",
        "fontWeight": "normal",
        "color": "$textPrimary"
    },
    "DefaultTextBig": {
        "font": "Sans",
        "fontSize": 22.0,
        "fontSlant": "normal",
        "fontWeight": "bold"
    },
    "Default": {
        "background": {
            "color": "$secondaryClick"
        }
    },
    "Panel": {
        "elevation": 1.0,
        "border": {
            "radius": 8.0,
            "color": "$borderDark",
            "width": 1.0
        },
        "background": {
            "color": "$panelBackground"
        }
    },
    "Button": {
        "padding": {
            "horizontal": 16.0,
            "vertical": 8.0
        },
        "normal": {
            "elevation": 0.0,
            "border": {
                "radius": 6.0,
                "color": "$primaryDark",
                "width": 1.0
            },
            "background": {
                "color": "$primaryDark"
            },
            "text": {
                "color": "$textPrimary"
            }
        },
        "hover": {
            "elevation": 0.0,
            "border": {
                "radius": 6.0,
                "color": "$primaryHoverDark",
                "width": 1.0
            },
            "background": {
                "color": "$primaryHoverDark"
            },
            "text": {
                "color": "$textPrimary"
            }
        },
        "click": {
            "elevation": 0.0,
            "border": {
                "radius": 6.0,
                "color": "$primaryClickDark",
                "width": 1.0
            },
            "background": {
                "color": "$primaryClickDark"
            },
            "text": {
                "color": "$textPrimary"
            }
        }
    },
    "Scrollbar": {
        "track": {
            "border": {
                "radius": 999.0,
                "color": "$borderDark",
                "width": 0.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "thumb": {
            "normal": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbNormalBorder",
                    "width": 0.0
                },
                "background": {
                    "color": "$secondary"
                }
            },
            "hover": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbHoverBorder",
                    "width": 0.0
                },
                "background": {
                    "color": "$thumbHoverBackground"
                }
            },
            "click": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbClickBorder",
                    "width": 0.0
                },
                "background": {
                    "color": "$thumbClickBackground"
                }
            }
        }
    },
    "Slider": {
        "track": {
            "border": {
                "radius": 999.0,
                "color": "$borderDark",
                "width": 0.0
            },
            "background": {
                "color": "$secondary"
            }
        },
        "thumb": {
            "normal": {
                "elevation": 3.0,
                "border": {
                    "radius": 999.0,
                    "color": "$primary",
                    "width": 0.0
                },
                "background": {
                    "color": "$primary"
                }
            },
            "hover": {
                "elevation": 3.0,
                "border": {
                    "radius": 999.0,
                    "color": "$primaryHover",
                    "width": 0.0
                },
                "background": {
                    "color": "$primaryHover"
                }
            },
            "click": {
                "elevation": 1.0,
                "border": {
                    "radius": 999.0,
                    "color": "$primaryClick",
                    "width": 0.0
                },
                "background": {
                    "color": "$primaryClick"
                }
            }
        }
    },
    "Edit": {
        "padding": {
            "horizontal": 12.0,
            "vertical": 6.0
        },
        "normal": {
            "border": {
                "radius": 6.0,
                "color": "$secondary",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "hover": {
            "border": {
                "radius": 6.0,
                "color": "$secondaryHover",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "focused": {
            "border": {
                "radius": 6.0,
                "color": "$focusBlue",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        }
    },
    "Selection": {
        "background": {
            "color": "$selectionBlue"
        }
    },
    "Switch": {
        "track": {
            "off": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchOffBorder",
                    "width": 0.0
                },
                "background": {
                    "color": "$switchOffBackground"
                }
            },
            "on": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchOnBackground",
                    "width": 0.0
                },
                "background": {
                    "color": "$switchOnBackground"
                }
            }
        },
        "thumb": {
            "normal": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbNormalBorder",
                    "width": 0.0
                },
                "background": {
                    "color": "$switchThumbBackground"
                }
            },
            "hover": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbHoverBorder",
                    "width": 0.0
                },
                "background": {
                    "color": "$switchThumbHoverBackground"
                }
            },
            "click": {
                "border": {
                    "radius": 999.0,
                    "color": "$thumbClickBorder",
                    "width": 0.0
                },
                "background": {
                    "color": "$switchThumbClickBackground"
                }
            },
            "normalOn": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbOnBackground",
                    "width": 0.0
                },
                "background": {
                    "color": "$switchThumbOnBackground"
                }
            },
            "hoverOn": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbOnHoverBackground",
                    "width": 0.0
                },
                "background": {
                    "color": "$switchThumbOnHoverBackground"
                }
            },
            "clickOn": {
                "border": {
                    "radius": 999.0,
                    "color": "$switchThumbOnClickBackground",
                    "width": 0.0
                },
                "background": {
                    "color": "$switchThumbOnClickBackground"
                }
            }
        }
    },
    "CheckBox": {
        "size": 16.0,
        "normal": {
            "border": {
                "radius": 4.0,
                "color": "$switchOffBorder",
                "width": 1.0
            },
            "background": {
                "color": "$switchOffBackground"
            }
        },
        "hover": {
            "border": {
                "radius": 4.0,
                "color": "$checkboxHoverBorder",
                "width": 1.0
            },
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 4.0,
                "color": "$secondaryHover",
                "width": 1.0
            },
            "background": {
                "color": "$clickBackground"
            }
        },
        "checked": {
            "border": {
                "radius": 4.0,
                "color": "$primary",
                "width": 1.0
            },
            "background": {
                "color": "$accentDark"
            }
        },
        "checkedHover": {
            "border": {
                "radius": 4.0,
                "color": "$primaryHover",
                "width": 1.0
            },
            "background": {
                "color": "$accentHoverDark"
            }
        },
        "checkmark": {
            "stroke": {
                "color": "$onPrimary",
                "width": 2.0
            },
            "lineCap": "round",
            "lineJoin": "round",
            "svg": "M20 6 9 17l-5-5"
        }
    },
    "RadioButton": {
        "size": 16.0,
        "normal": {
            "border": {
                "radius": 999.0,
                "color": "$switchOffBorder",
                "width": 1.0
            },
            "background": {
                "color": "$switchOffBackground"
            }
        },
        "hover": {
            "border": {
                "radius": 999.0,
                "color": "$checkboxHoverBorder",
                "width": 1.0
            },
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 999.0,
                "color": "$secondaryHover",
                "width": 1.0
            },
            "background": {
                "color": "$clickBackground"
            }
        },
        "selected": {
            "border": {
                "radius": 999.0,
                "color": "$primary",
                "width": 1.0
            },
            "background": {
                "color": "$accentDark"
            }
        },
        "selectedHover": {
            "border": {
                "radius": 999.0,
                "color": "$primaryHover",
                "width": 1.0
            },
            "background": {
                "color": "$accentHoverDark"
            }
        },
        "dot": {
            "border": {
                "radius": 999.0,
                "color": "$onPrimary",
                "width": 0.0
            },
            "background": {
                "color": "$onPrimary"
            }
        }
    },
    "Menu": {
        "elevation": 8.0,
        "padding": {
            "horizontal": 5.0,
            "vertical": 5.0
        },
        "border": {
            "radius": 8.0,
            "color": "$borderDark",
            "width": 1.0
        },
        "background": {
            "color": "$panelBackground"
        }
    },
    "MenuItem": {
        "padding": {
            "horizontal": 8.0,
            "vertical": 6.0
        },
        "normal": {
            "background": {
                "color": "#00000000"
            }
        },
        "hover": {
            "border": {
                "radius": 4.0,
                "color": "#00000000",
                "width": 0.0
            },
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 4.0,
                "color": "#00000000",
                "width": 0.0
            },
            "background": {
                "color": "$menuItemClick"
            }
        },
        "arrow": {
            "stroke": {
                "color": "$textSecondary",
                "width": 1.5
            },
            "lineCap": "round",
            "lineJoin": "round",
            "svg": "m9 18 6-6-6-6"
        }
    },
    "MenuSeparator": {
        "color": "$borderDark",
        "margin": {
            "horizontal": 4.0,
            "vertical": 4.0
        }
    },
    "List": {
        "padding": 4.0,
        "border": {
            "radius": 8.0,
            "color": "$borderDark",
            "width": 1.0
        },
        "background": {
            "color": "$backgroundDark"
        },
        "item": {
            "height": 22.0,
            "padding": {
                "vertical": 6.0,
                "horizontal": 8.0
            }
        },
        "itemSelected": {
            "border": {
                "radius": 4.0,
                "color": "$secondary",
                "width": 0.0
            },
            "background": {
                "color": "$secondary"
            },
            "text": {
                "color": "$textPrimary",
                "fontWeight": "normal"
            }
        }
    },
    "ToolButton": {
        "padding": {
            "horizontal": 8.0,
            "vertical": 8.0
        },
        "hover": {
            "border": {
                "radius": 6.0,
                "color": "#00000000",
                "width": 0.0
            },
            "background": {
                "color": "$hoverBackground"
            }
        },
        "click": {
            "border": {
                "radius": 6.0,
                "color": "#00000000",
                "width": 0.0
            },
            "background": {
                "color": "$menuItemClick"
            }
        }
    },
    "ProgressBar": {
        "track": {
            "border": {
                "radius": 999.0,
                "color": "$borderDark",
                "width": 0.0
            },
            "background": {
                "color": "$secondary"
            }
        },
        "progress": {
            "border": {
                "radius": 999.0,
                "color": "$primary",
                "width": 0.0
            },
            "background": {
                "color": "$primary"
            }
        },
        "indeterminate": {
            "background": {
                "linearGradient": {
                    "start": [
                        0.0,
                        0.0
                    ],
                    "end": [
                        1.0,
                        0.0
                    ],
                    "stops": [
                        0.0,
                        0.5,
                        1.0
                    ],
                    "colors": [
                        "$primaryDarkTransparent",
                        "$primary",
                        "$primaryDarkTransparent"
                    ]
                }
            }
        }
    },
    "Spinner": {
        "normal": {
            "border": {
                "radius": 6.0,
                "color": "$secondary",
                "width": 1.0
            },
            "background": {
                "color": "$backgroundDark"
            }
        },
        "button": {
            "hover": {
                "border": {
                    "radius": 0.0,
                    "color": "#00000000",
                    "width": 0.0
                },
                "background": {
                    "color": "$spinnerButtonHover"
                }
            },
            "click": {
                "border": {
                    "radius": 0.0,
                    "color": "#00000000",
                    "width": 0.0
                },
                "background": {
                    "color": "$spinnerButtonClick"
                }
            }
        }
    },
    "Tooltip": {
        "font": "Sans",
        "fontSize": 13.0,
        "color": "#FF18181B",
        "padding": 5.0,
        "elevation": 2.0,
        "border": {
            "radius": 2.0,
            "color": "$borderDark",
            "width": 1.0
        },
        "background": {
            "color": "$backgroundLight"
        }
    }
}