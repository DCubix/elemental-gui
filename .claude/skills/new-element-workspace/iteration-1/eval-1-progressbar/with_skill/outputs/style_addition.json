"ProgressBar": {
    "track": {
        "border": {
            "radius": 6.0,
            "color": "#FF333333",
            "width": 1.0
        },
        "background": {
            "color": "#FF141414"
        }
    },
    "progress": {
        "border": {
            "radius": 6.0,
            "color": "#FF3859A6",
            "width": 1.0
        },
        "background": {
            "color": "#FF294580"
        }
    },
    "indeterminate": {
        "background": {
            "linearGradient": {
                "start": [ 0.0, 0.0 ],
                "end": [ 1.0, 0.0 ],
                "stops": [ 0.0, 0.5, 1.0 ],
                "colors": [ "#00294580", "#FF3859A6", "#00294580" ]
            }
        }
    }
}
